\mainlanguage[russian]
\language[russian]
\enableregime[utf]
\pdfvariable minorversion 5
\setupbodyfont[gentium, 11pt]  %
\setuppapersize[A4] % letter, portrait; A3, A4, A5, A6; landscape

% Отладка
% \showframe
% \showgrid

\setupbodyfontenvironment[default][em=italic]

\setupcolors[state=start]
\setupcolor[rgb]

%%% Section desing %%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

\define[2]\CVSection{
    \framedtext[
        framecolor=darkblue,
        color=darkblue,
        width=\makeupwidth,
        offset=2pt,
        bottomframe=on,
        align=flushleft,
        frame=off,
        strut=no,
    ]{#2}
}

\setuphead[section][
    command=\CVSection,
    margin=-4pt,
    rightmargin=10pt,
    style={\switchtobodyfont[14pt]\bf},
    before={\vskip 1mm},
]

\setupitemize[each][joinedup][leftmargin=0em]

%A4 210 x 297 mm
%letter 215.9 x 279.4

\setuplayout[
    width=195mm,
    height=285mm,
    backspace=8mm,
    topspace=5mm,
    top=0mm,
    header=5mm,
    footer=8mm,
    bottom=3mm,
    margin=20mm,
    rightedgedistance=15mm,
    rightedge=70mm,
]

\setuppagenumbering[location=]
\setupfootertexts[{\sc Страница \currentpage{} из \lastpage}]

% For \url:

\setupurl[
    color=black,
    style=\tf,
]

% For \goto and \from:

\setupinteraction[
    state=start,
    color=black,
    style=\tf,
]

\setupexternalfigures[
    directory={./images},
    conversion=pdf,
]

