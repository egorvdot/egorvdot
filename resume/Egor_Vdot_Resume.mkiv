\section{Профессиональный опыт}

\define[3]\Employment{
    \setupframed[
        height=1cm,
        frame=off,
    ]
    \startcombination[2]
        {
            \framed[
                align=right,
                bottom=\vss,
                top=\vss,
                width=12.5cm,
            ]{%
                {\bfa #1}\\
                {\sc #2}
            }
        }{}
        {
            \framed[
                align=flushright,
                bottom=\vss,
                top=\vss,
                width=6.5cm,
            ]{%
                {\bf #3}
            }
        }{}
    \stopcombination
}


\useURL[adr][https://github.com/joelparkerhenderson/architecture-decision-record][][Architecture Decision Log]

\Employment{Центр Финансовых Технологий -- Удаленно}
    {Ведущий инженер машинного обучения}
    {2022/10~--~до~настоящего~времени}
\placefigure[right,none]{none}{\externalfigure[cft_logo_ru.png][width=4cm]}
\startitemize
% \item Вхожу в роль тимлида на проекте скоринга.
\item Организую оперативное реагирование на проблемы в production, внедряя Monitoring as Code в отделе разработки.
\item Сократил затраты на поиск джуниоров, проведя внешний образовательный курс.
\item Обеспечил долгосрочный рост квалификации сотрудников отдела, внедрив {\from[adr]}.
\item Удовлетворил требования GDPR к технической инфраструктуре для Европейской части бизнеса.
\item Оперативно завершил затянувшийся рефакторинг на сервисе распознавания документов.
\item Стабилизировал обработку запросов на сервисах с Computer Vision моделями.
\stopitemize

\blank

\Employment{Network Optix -- Удаленно}
    {Software Engineer in Test}
    {2021/08~--~2022/09}
\placefigure[right,none]{none}{\externalfigure[Nx_Logo.png][width=4cm]}
\startitemize
\item Обеспечил надежную доставку отчетов тестирования для доступа к информации о результатах верификации качества.
\item Настроил CI для развертывания сервиса отчетности.
\item Развивал систему верификации функционала продукта для повышения его качества.
% \item Купировал потерю данных о ночных запусках автотестов
% \item Реализовал надежную доставку отчетных данных до сервиса отчетности на основе SQLite.
\stopitemize

\blank

\Employment{Центр Финансовых Технологий -- Новосибирск}
    {Ведущий инженер-программист}
    {2018/10~--~2021/07}
\placefigure[right,none]{none}{\externalfigure[cft_logo_ru.png][width=4cm]}
\startitemize
\item Закрыл потенциальный поток фрода, сэкономив компании более 1 млн рублей в неделю.
\item Стабилизировал поставку бизнес-ценности на сервисе скоринга, обеспечив выполнение типовых задач за 1-2 дня.
\item Ускорил обработку заявок от клиентов, заменив ручную обработку сервисом скоринга.
\item Ускорил доставку изменений в сервисах подразделения до production с нескольких дней до нескольких минут.
\item Сократил трудозатраты на вхождение и поддержку сервиса валидации анкеты с нескольких дней до нескольких часов.
\stopitemize


